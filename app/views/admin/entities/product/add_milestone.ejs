<style>
#milestone-form .form-control {
  font-size: 1rem;
  padding: 0.9rem 1rem;
  border-radius: 1.5rem;
  border: 2px solid #007bff;
  width: 100%;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

#milestone-form .form-control:focus {
  border-color: #0056b3;
  box-shadow: 0 0 5px rgba(0, 91, 187, 0.25);
}

#milestone-form .task-input-group {
  margin-bottom: 0.75rem;
}

#milestone-form .task-input-group .col-md-6,
#milestone-form .task-input-group .col-md-5 {
  padding-right: 0.75rem;
}

#milestone-form .task-input-group .col-md-1 {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 0;
}

#milestone-form .remove-task {
  min-width: 42px;
  border-radius: 50px;
}

#milestone-form .card {
  border-radius: 1rem;
  overflow: hidden;
}

#milestone-form .card-header {
  font-size: 1.15rem;
  font-weight: 700;
  background: linear-gradient(135deg, #007bff, #0056b3);
  color: white;
  text-transform: uppercase;
}

#milestone-form .btn-primary {
  background: linear-gradient(135deg, #007bff, #0056b3);
  border: none;
  border-radius: 50px;
  font-size: 1.05rem;
}

#milestone-form #add-task {
  background-color: #28a745;
  color: white;
  border-radius: 50px;
}

#milestone-form #add-task:hover {
  background-color: #218838;
}

#milestone-form #due_date {
  width: 100%;
  height: 45px;
  padding: 10px 15px;
  border: 2px solid #007bff;
  border-radius: 25px;
  font-size: 1rem;
  appearance: none;
}

#milestone-form textarea {
  border-radius: 1rem;
}

#milestone-form #due_date::-webkit-calendar-picker-indicator {
  cursor: pointer;
  opacity: 0.8;
  font-size: 1.2rem;
}

#milestone-form .btn-primary:hover {
  background: linear-gradient(135deg, #0056b3, #003580);
}

</style>
