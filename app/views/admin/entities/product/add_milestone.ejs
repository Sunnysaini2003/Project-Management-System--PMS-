<!-- Milestone Form  -->
<div id="milestone-form" class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow border-0">
        <div class="card-header bg-primary text-white text-center py-3">
          <h5 class="mb-0"><%= data.edit ? 'Edit Milestone' : 'Add New Milestone' %></h5>
        </div>
        <div class="card-body p-4">
          <form action="<%= data.edit ? '/admin/milestones/update/' + data.milestone.id : '/admin/milestones/add_milestone' %>" method="POST">
            
            <!-- Milestone Input -->
            <div class="form-group mb-4">
              <label for="milestone" class="font-weight-bold">
                <i class="bi bi-geo text-primary mr-2"></i> Milestone
              </label>
              <input 
                type="text" 
                id="milestone" 
                name="milestone" 
                class="form-control border-primary rounded-pill p-3" 
                placeholder="Enter milestone" 
                value="<%= data.milestone ? data.milestone.milestone : '' %>"
                required>
            </div>

            <!-- Dynamic Task Input Section -->
            <div class="form-group mb-4">
              <label class="font-weight-bold">
                <i class="fas fa-list-check text-primary mr-2"></i> Assign Tasks
              </label>
              <div id="tasks-container">
                <% if (data.tasks && data.tasks.length > 0) { %>
                  <% data.tasks.forEach((task, taskIndex) => { %>
                    <div class="task-input-group row align-items-center no-gutters mb-2">
                      <div class="col-12 col-md-6">
                        <input type="text" name="tasks[]" class="form-control border-primary" placeholder="Enter task" value="<%= task.task_name %>" required>
                      </div>
                      <div class="col-12 col-md-5">
                        <input type="text" name="assigned_to[]" class="form-control border-success" placeholder="Assign to (name or team)" value="<%= task.assigned_to || '' %>" required>
                      </div>
                      <div class="col-12 col-md-1 text-right">
                        <button type="button" class="btn btn-danger btn-sm remove-task <%= taskIndex === 0 ? 'd-none' : '' %>"><i class="bi bi-trash"></i></button>
                      </div>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="task-input-group row align-items-center no-gutters mb-2">
                    <div class="col-12 col-md-6">
                      <input type="text" name="tasks[]" class="form-control border-primary" placeholder="Enter task" required>
                    </div>
                    <div class="col-12 col-md-5">
                      <input type="text" name="assigned_to[]" class="form-control border-success" placeholder="Assign to (name or team)" required>
                    </div>
                    <div class="col-12 col-md-1 text-right">
                      <button type="button" class="btn btn-danger btn-sm remove-task d-none"><i class="bi bi-trash"></i></button>
                    </div>
                  </div>
                <% } %>
              </div>
              <button type="button" class="btn btn-success mt-2 px-3 py-2" id="add-task">
                <i class="bi bi-plus-circle"></i> Add Task
              </button>
            </div>

            <!-- Due Date Input -->
            <div class="form-group mb-5">
              <label for="due_date" class="form-label fw-bold">
                <i class="bi bi-calendar-date text-primary me-2"></i> Due Date
              </label>
              <input 
                type="date" 
                id="due_date"
                name="due_date" 
                class="form-control"
                value="<%= data.milestone && data.milestone.due_date ? (new Date(data.milestone.due_date)).toISOString().slice(0, 10) : '' %>"
                required>
            </div>
            
            <!-- Description Input -->
            <div class="form-group mb-4">
              <label for="description" class="form-label fw-bold">
                <i class="bi bi-chat-text text-primary me-2"></i> Description
              </label>
              <textarea 
                id="description" 
                name="description" 
                class="form-control border-primary rounded p-3" 
                placeholder="Enter milestone description" 
                rows="4" 
                required><%= data.milestone ? data.milestone.description : '' %></textarea>
            </div>

            <!-- Submit Button -->
            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-lg rounded-pill">
                <i class="bi bi-save me-2"></i> Save Milestone
              </button>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div> 
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const taskContainer = document.getElementById("tasks-container");
    const addTaskBtn = document.getElementById("add-task");

    addTaskBtn.addEventListener("click", function() {
      const taskGroup = document.createElement("div");
      taskGroup.classList.add("task-input-group", "row", "align-items-center", "no-gutters", "mb-2");

      taskGroup.innerHTML = `
        <div class="col-12 col-md-6">
          <input type="text" name="tasks[]" class="form-control border-primary" placeholder="Enter task" required>
        </div>
        <div class="col-12 col-md-5">
          <input type="text" name="assigned_to[]" class="form-control border-success" placeholder="Assign to (name or team)" required>
        </div>
        <div class="col-12 col-md-1 text-right">
          <button type="button" class="btn btn-danger btn-sm remove-task"><i class="bi bi-trash"></i></button>
        </div>
      `;

      taskContainer.appendChild(taskGroup);
      updateRemoveButtons();
    });

    taskContainer.addEventListener("click", function (e) {
      if (e.target.closest('.remove-task')) {
        e.target.closest('.task-input-group').remove();
        updateRemoveButtons();
      }
    });

    function updateRemoveButtons() {
      const removeButtons = taskContainer.querySelectorAll('.remove-task');
      removeButtons.forEach((btn, index) => {
        btn.classList.toggle('d-none', removeButtons.length === 1);
      });
    }

    updateRemoveButtons();
  });
</script>

